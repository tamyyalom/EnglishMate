# Required for the tutor API (server/index.ts). Get a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: defaults to gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# Optional: API port (default 8787). Must match Vite proxy in vite.config.ts
# PORT=8787

# Optional: when the built static app is served without the proxy, set the full API origin, e.g. https://api.example.com
# VITE_API_BASE_URL=http://127.0.0.1:8787
